# Supabase — https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_your_key

# Your deployed URL, no trailing slash
# Dev: http://localhost:3000  |  Prod: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Beehiiv — https://app.beehiiv.com/settings/integrations/api
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_AUDIENCE_ID=pub_your_publication_id

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
